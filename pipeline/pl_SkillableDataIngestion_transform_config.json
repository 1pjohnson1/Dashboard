              { "source": { "name": "SaveExpires", "type": "Int64" }, "sink": { "name": "SaveExpires", "type": "Int64" } },
              { "source": { "name": "StartTime", "type": "String" }, "sink": { "name": "StartTime", "type": "String" } },
              { "source": { "name": "EndTime", "type": "String" }, "sink": { "name": "EndTime", "type": "String" } },
              { "source": { "name": "LastActivityTime", "type": "String" }, "sink": { "name": "LastActivityTime", "type": "String" } },
              { "source": { "name": "ExpiresTime", "type": "String" }, "sink": { "name": "ExpiresTime", "type": "String" } },
              { "source": { "name": "LastSaveTime", "type": "String" }, "sink": { "name": "LastSaveTime", "type": "String" } },
              { "source": { "name": "SaveExpiresTime", "type": "String" }, "sink": { "name": "SaveExpiresTime", "type": "String" } },
              { "source": { "name": "State", "type": "String" }, "sink": { "name": "State", "type": "String" } },
              { "source": { "name": "CompletionStatus", "type": "String" }, "sink": { "name": "CompletionStatus", "type": "String" } },
              { "source": { "name": "IpAddress", "type": "String" }, "sink": { "name": "IpAddress", "type": "String" } },
