              { "source": { "name": "BrowserUserAgent", "type": "String" }, "sink": { "name": "BrowserUserAgent", "type": "String" } },
              { "source": { "name": "RemoteController", "type": "String" }, "sink": { "name": "RemoteController", "type": "String" } },
              { "source": { "name": "Language", "type": "String" }, "sink": { "name": "Language", "type": "String" } },
              { "source": { "name": "PlatformId", "type": "Int32" }, "sink": { "name": "PlatformId", "type": "Int32" } },
              { "source": { "name": "ApiConsumerName", "type": "String" }, "sink": { "name": "ApiConsumerName", "type": "String" } },
