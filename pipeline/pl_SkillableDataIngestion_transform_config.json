{
  "name": "pl_SkillableDataIngestion_transform",
  "properties": {
    "activities": [
      {
        "name": "GetLatestRawIngestRun",
        "description": "Dependency check: find the latest successful RawIngest run to ensure data is available",
        "type": "SqlServerStoredProcedure",
        "dependsOn": [],
        "policy": {
          "timeout": "0.01:00:00",
          "retry": 1,
          "retryIntervalInSeconds": 30,
          "secureOutput": false,
          "secureInput": false
        },
        "userProperties": [],
        "linkedServiceName": {
          "referenceName": "ls_AzureSql",
          "type": "LinkedServiceReference"
        },
        "typeProperties": {
          "storedProcedureName": "dbo.usp_GetLatestRawIngestRun",
          "storedProcedureParameters": {
            "RunId": {
              "value": null,
              "type": "Guid",
              "direction": "Output"
            }
          }
        }
      },
      {
        "name": "LogTransformStart",
        "description": "Log the start of the Transform pipeline run",
        "type": "SqlServerStoredProcedure",
        "dependsOn": [
          {
            "activity": "GetLatestRawIngestRun",
            "dependencyConditions": [
              "Succeeded"
            ]
          }
        ],
        "policy": {
          "timeout": "0.01:00:00",
          "retry": 1,
          "retryIntervalInSeconds": 30,
          "secureOutput": false,
          "secureInput": false
        },
        "userProperties": [],
        "linkedServiceName": {
          "referenceName": "ls_AzureSql",
          "type": "LinkedServiceReference"
        },
        "typeProperties": {
          "storedProcedureName": "dbo.usp_LogPipelineRun",
          "storedProcedureParameters": {
            "PipelineName": {
              "value": "Transform",
              "type": "String"
            },
            "Status": {
              "value": "Started",
              "type": "String"
            },
            "RunId": {
              "value": null,
              "type": "Guid",
              "direction": "Output"
            }
          }
        }
      },
      {
        "name": "CopyRawToNormalized",
        "description": "Copy and normalize data from tblInstancesRaw to tblInstances. Handles field selection, JSON serialization, and timestamp management.",
        "type": "Copy",
        "dependsOn": [
          {
            "activity": "LogTransformStart",
            "dependencyConditions": [
              "Succeeded"
            ]
          }
        ],
        "policy": {
          "timeout": "1.00:00:00",
          "retry": 2,
          "retryIntervalInSeconds": 60,
          "secureOutput": false,
          "secureInput": false
        },
        "userProperties": [],
        "typeProperties": {
          "source": {
            "type": "AzureSqlSource",
            "sqlReaderQuery": {
              "value": "SELECT\n  Id, LabProfileId, LabProfileName, SeriesId, SeriesName,\n  UserFirstName, UserLastName, UserEmail,\n  InstructorName, InstructorEmail,\n  [Start], [End], LastActivity, Expires, LastSave, SaveExpires,\n  StartTime, EndTime, LastActivityTime, ExpiresTime, LastSaveTime, SaveExpiresTime,\n  [State], CompletionStatus,\n  IpAddress, Country, Region, City, Latitude, Longitude,\n  DatacenterId, DatacenterName, DeliveryRegionId, DeliveryRegionName,\n  LabHostId, LabHostName, PoolMemberName,\n  StartupDuration, EstimatedReadySeconds, TotalRunTime, TimeInSession, TimeRemaining,\n  ErrorCount, LastLatency,\n  CONVERT(NVARCHAR(MAX), Errors) AS Errors,\n  IsExam, ExamPassed, ExamScore, ExamMaxPossibleScore, ExamPassingScore,\n  TaskCompletePercent,\n  CONVERT(NVARCHAR(MAX), ScriptResults) AS ScriptResults,\n  LastSaveTriggerType, BrowserUserAgent, RemoteController, [Language],\n  PlatformId, ApiConsumerName,\n  CONVERT(NVARCHAR(MAX), Notes) AS Notes,\n  CONVERT(NVARCHAR(MAX), Sessions) AS Sessions\nFROM dbo.tblInstancesRaw",
              "type": "Expression"
            },
            "queryTimeout": "02:00:00"
          },
          "sink": {
            "type": "AzureSqlSink",
            "writeBehavior": "insert",
            "sqlWriterUseTableLock": false,
            "disableMetricsCollection": false
          },
          "enableStaging": false,
          "translator": {
            "type": "TabularTranslator",
            "mappings": [
              { "source": { "name": "Id", "type": "Int32" }, "sink": { "name": "Id", "type": "Int32" } },
              { "source": { "name": "LabProfileId", "type": "Int32" }, "sink": { "name": "LabProfileId", "type": "Int32" } },
              { "source": { "name": "LabProfileName", "type": "String" }, "sink": { "name": "LabProfileName", "type": "String" } },
              { "source": { "name": "SeriesId", "type": "Int32" }, "sink": { "name": "SeriesId", "type": "Int32" } },
              { "source": { "name": "SeriesName", "type": "String" }, "sink": { "name": "SeriesName", "type": "String" } },
              { "source": { "name": "UserFirstName", "type": "String" }, "sink": { "name": "UserFirstName", "type": "String" } },
              { "source": { "name": "UserLastName", "type": "String" }, "sink": { "name": "UserLastName", "type": "String" } },
              { "source": { "name": "UserEmail", "type": "String" }, "sink": { "name": "UserEmail", "type": "String" } },
              { "source": { "name": "InstructorName", "type": "String" }, "sink": { "name": "InstructorName", "type": "String" } },
              { "source": { "name": "InstructorEmail", "type": "String" }, "sink": { "name": "InstructorEmail", "type": "String" } },
              { "source": { "name": "Start", "type": "Int64" }, "sink": { "name": "Start", "type": "Int64" } },
              { "source": { "name": "End", "type": "Int64" }, "sink": { "name": "End", "type": "Int64" } },
              { "source": { "name": "LastActivity", "type": "Int64" }, "sink": { "name": "LastActivity", "type": "Int64" } },
              { "source": { "name": "Expires", "type": "Int64" }, "sink": { "name": "Expires", "type": "Int64" } },
