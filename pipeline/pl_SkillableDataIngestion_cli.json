{
    "activities": [
        {
            "name": "GetApiKey",
            "description": "Retrieve Skillable API key from Key Vault",
            "type": "WebActivity",
            "dependsOn": [],
            "policy": {
                "timeout": "0.12:00:00",
                "retry": 0,
                "retryIntervalInSeconds": 30,
                "secureOutput": false,
                "secureInput": false
            },
            "userProperties": [],
            "typeProperties": {
                "method": "GET",
                "url": "https://kv-skillable-dashboard.vault.azure.net/secrets/SkillableApiKey?api-version=7.0",
                "authentication": {
                    "type": "MSI",
                    "resource": "https://vault.azure.net"
                }
            }
        },
        {
            "name": "SetApiKey",
            "description": "Store the API key in a variable",
            "type": "SetVariable",
            "dependsOn": [
                {
                    "activity": "GetApiKey",
                    "dependencyConditions": [
                        "Succeeded"
                    ]
                }
            ],
            "policy": {
                "secureOutput": true,
                "secureInput": false
            },
            "userProperties": [],
            "typeProperties": {
                "variableName": "ApiKeyVar",
                "value": {
                    "value": "@activity('GetApiKey').output.value",
                    "type": "Expression"
                }
            }
        },
        {
            "name": "GetFirstPageAndCount",
            "description": "Activity 1-Web Activity: GetFirstPageAndCount",
            "type": "WebActivity",
            "dependsOn": [
                {
                    "activity": "SetApiKey",
                    "dependencyConditions": [
                        "Succeeded"
                    ]
                }
            ],
            "policy": {
                "timeout": "0.12:00:00",
                "retry": 1,
                "retryIntervalInSeconds": 30,
                "secureOutput": false,
                "secureInput": false
            },
            "userProperties": [],
            "typeProperties": {
                "method": "GET",
                "headers": {
                    "api_key": {
                        "value": "@variables('ApiKeyVar')",
                        "type": "Expression"
                    }
                },
                "url": {
                    "value": "@concat('https://labondemand.com/api/v3/labinstance/search?start=', string(pipeline().parameters.StartEpoch), '&end=', string(pipeline().parameters.EndEpoch), '&pageIndex=0&pageSize=', string(pipeline().parameters.PageSize), '&sort=start%20desc&mode=10')",
                    "type": "Expression"
                }
            }
        },
        {
            "name": "SetTotalPages",
            "type": "SetVariable",
            "dependsOn": [
                {
                    "activity": "GetFirstPageAndCount",
                    "dependencyConditions": [
                        "Succeeded"
                    ]
                }
            ],
            "policy": {
                "secureOutput": false,
                "secureInput": false
            },
            "userProperties": [],
            "typeProperties": {
                "variableName": "TotalPages",
                "value": "@add(div(activity('GetFirstPageAndCount').output.TotalResults, pipeline().parameters.PageSize), if(equals(mod(activity('GetFirstPageAndCount').output.TotalResults, pipeline().parameters.PageSize), 0), 0, 1))"
            }
        },
        {
            "name": "BuildPageArray",
            "type": "SetVariable",
            "dependsOn": [
                {
                    "activity": "SetTotalPages",
                    "dependencyConditions": [
                        "Succeeded"
                    ]
                }
            ],
            "policy": {
                "secureOutput": false,
                "secureInput": false
            },
            "userProperties": [],
            "typeProperties": {
                "variableName": "PageArray",
                "value": "@range(0, variables('TotalPages'))"
            }
        },
        {
            "name": "ForEachPage",
            "type": "ForEach",
            "dependsOn": [
                {
                    "activity": "BuildPageArray",
                    "dependencyConditions": [
                        "Succeeded"
                    ]
                }
            ],
            "userProperties": [],
            "typeProperties": {
                "items": {
                    "value": "@variables('PageArray')",
                    "type": "Expression"
                },
                "isSequential": true,
                "activities": [
                    {
                        "name": "CopySearchResultsToSql",
                        "type": "Copy",
                        "dependsOn": [],
                        "policy": {
                            "timeout": "0.12:00:00",
                            "retry": 0,
                            "retryIntervalInSeconds": 30,
                            "secureOutput": false,
                            "secureInput": false
                        },
                        "userProperties": [],
                        "typeProperties": {
                            "source": {
                                "type": "RestSource",
                                "httpRequestTimeout": "00:01:40",
                                "requestInterval": "00.00:00:00.010",
                                "requestMethod": "GET",
                                "paginationRules": {
                                    "supportRFC5988": "true"
                                }
                            },
                            "sink": {
                                "type": "AzureSqlSink",
                                "writeBehavior": "upsert",
                                "upsertSettings": {
                                    "useTempDB": true,
                                    "keys": {
                                        "value": "@createArray('Id')\n",
                                        "type": "Expression"
                                    }
                                },
                                "sqlWriterUseTableLock": false,
                                "disableMetricsCollection": false
                            },
                            "enableStaging": false,
                            "translator": {
                                "type": "TabularTranslator",
                                "mapComplexValuesToString": false
                            }
                        },
                        "inputs": [
                            {
                                "referenceName": "ds_SkillableSearch",
                                "type": "DatasetReference",
                                "parameters": {
                                    "relativeUrl": {
                                        "value": "@concat('labinstance/search?start=', string(pipeline().parameters.StartEpoch), '&end=', string(pipeline().parameters.EndEpoch), '&pageIndex=', string(item()), '&pageSize=', string(pipeline().parameters.PageSize), '&sort=start%20desc&mode=10')",
                                        "type": "Expression"
                                    }
                                }
                            }
                        ],
                        "outputs": [
                            {
                                "referenceName": "ds_SqlInstances",
                                "type": "DatasetReference",
                                "parameters": {}
                            }
                        ]
                    }
                ]
            }
        }
    ],
    "policy": {
        "elapsedTimeMetric": {}
    },
    "parameters": {
        "StartEpoch": {
            "type": "int"
        },
        "EndEpoch": {
            "type": "int"
        },
        "PageSize": {
            "type": "int",
            "defaultValue": 10
        }
    },
    "variables": {
        "ApiKeyVar": {
            "type": "String",
            "defaultValue": ""
        },
        "TotalResults": {
            "type": "Integer",
            "defaultValue": 0
        },
        "TotalPages": {
            "type": "Integer",
            "defaultValue": 0
        },
        "PageArray": {
            "type": "Array",
            "defaultValue": []
        }
    },
    "annotations": []
}